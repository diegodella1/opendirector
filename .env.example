# OpenDirector Docker Configuration
# Copy to .env and customize if needed.
# All values have sensible defaults — you can run `docker compose up` without any .env file.

# PostgreSQL password
DB_PASSWORD=opendirector

# JWT secret shared between PostgREST and the app (change in production!)
JWT_SECRET=super-secret-jwt-token-for-opendirector-at-least-32-chars

# Host port for the webapp
PORT=3000
